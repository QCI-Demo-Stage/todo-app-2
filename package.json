{
  "name": "workspace",
  "version": "1.0.0",
  "description": "Initialized by Tymeline so the AI Employee can run tasks.",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc && mkdir -p dist/src/docs && cp src/docs/openapi.yaml dist/src/docs/openapi.yaml",
    "build:client": "vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "axe": "start-server-and-test \"vite preview --host 127.0.0.1 --port 4173\" http://127.0.0.1:4173 \"node scripts/axe.mjs\"",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:client": "vite",
    "start": "node dist/src/index.js",
    "test-db": "ts-node scripts/test-db-connection.ts",
    "validate-openapi": "swagger-cli validate src/docs/openapi.yaml && ts-node scripts/validate-openapi-routes.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QCI-Demo-Stage/todo-app-2.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/QCI-Demo-Stage/todo-app-2/issues"
  },
  "homepage": "https://github.com/QCI-Demo-Stage/todo-app-2#readme",
  "dependencies": {
    "@reduxjs/toolkit": "^2.8.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "joi": "^18.1.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-redux": "^9.2.0",
    "react-toastify": "^11.0.5",
    "sqlite3": "^6.0.1",
    "swagger-ui-express": "^5.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@apidevtools/swagger-cli": "^4.0.4",
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "start-server-and-test": "^3.0.2",
    "ts-node": "^10.9.2",
    "vite": "^6.3.0"
  }
}
