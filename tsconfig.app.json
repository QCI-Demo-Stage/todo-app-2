{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": ["src/**/*.tsx", "src/**/*.ts", "vite.config.ts"],
  "exclude": [
    "src/db/**",
    "src/docs/**",
    "src/errors/**",
    "src/index.ts",
    "src/middleware/**",
    "src/models/**",
    "src/routes/**",
    "src/validation/**"
  ]
}
